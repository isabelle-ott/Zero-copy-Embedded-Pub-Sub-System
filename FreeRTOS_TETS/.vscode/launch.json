{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32 (OpenOCD)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/FreeRTOS_TETS.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "toolchainPrefix": "arm-none-eabi", // <--- 新增这一行，打破插件的错误推断
            "gdbPath": "gdb-multiarch",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "rtos": "FreeRTOS"
        }
    ]
}